# .env.example - Copy to .env.local dan isi dengan nilai asli

# OpenAI
NUXT_PUBLIC_OPENAI_API_KEY=sk_your_key_here
OPENAI_API_KEY=sk_your_key_here

# Supabase (Settings > API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_anon_public_key
SUPABASE_SERVICE_KEY=your_service_role_key

# Midtrans (Settings > Access Keys > Sandbox)
MIDTRANS_SERVER_KEY=Mid-server-xxxx
NUXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-xxxx
